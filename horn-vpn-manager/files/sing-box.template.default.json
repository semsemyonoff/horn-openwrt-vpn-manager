{
  "log": {
    "level": "warn"
  },
  "inbounds": [
    {
      "type": "tun",
      "interface_name": "tun0",
      "address": ["172.16.250.1/30"],
      "auto_route": false,
      "strict_route": false
    }
  ],
  "outbounds": [
    {"type": "direct", "tag": "direct"}
  ],
  "route": {
    "rules": [
      {"action": "sniff"}
    ],
    "auto_detect_interface": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090"
    },
    "cache_file": {
      "enabled": true,
      "path": "/etc/sing-box/clash.db"
    }
  }
}
