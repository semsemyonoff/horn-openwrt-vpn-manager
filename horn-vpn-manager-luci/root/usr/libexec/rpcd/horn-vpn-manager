#!/bin/sh
# shellcheck disable=SC3043

CONF_DIR="/etc/horn-vpn-manager"
SUBS_JSON="${CONF_DIR}/subs.json"
SUBS_SCRIPT="/usr/libexec/horn-vpn-manager/subs.sh"
TEMPLATE_FILE="${CONF_DIR}/config.template.json"
DEFAULT_TEMPLATE_FILE="/usr/share/horn-vpn-manager/config.template.default.json"
TAGS_FILE="${CONF_DIR}/subs-tags.json"
LOG_FILE="/tmp/horn-vpn-manager-sub.log"
PID_FILE="/tmp/horn-vpn-manager.pid"

DOMAINS_JSON="${CONF_DIR}/domains.json"
DOMAINS_SCRIPT="/usr/libexec/horn-vpn-manager/getdomains.sh"
DOMAINS_LOG="/tmp/horn-vpn-manager-domains.log"
DOMAINS_PID="/tmp/horn-vpn-manager-domains.pid"
MANUAL_IPS="${CONF_DIR}/lists/manual-ip.lst"

case "$1" in
    list)
        echo '{"get_config":{},"set_config":{"config":"Object"},"run_script":{"dry_run":"Boolean","verbose":"Number"},"get_log":{},"get_syslog":{"lines":"Number"},"test_url":{"url":"String"},"get_sb_status":{},"set_proxy":{"proxy":"String","selected":"String"},"test_delays":{"tags":"Array","url":"String"},"get_template":{},"set_template":{"template":"String"},"reset_template":{},"get_domains_config":{},"set_domains_config":{"config":"Object"},"get_manual_ips":{},"set_manual_ips":{"ips":"String"},"run_getdomains":{"verbose":"Number"},"get_domains_log":{},"get_manual_domains":{},"set_manual_domains":{"domains":"Array"}}'
        ;;
    call)
        case "$2" in
            get_config)
                if [ -f "$SUBS_JSON" ]; then
                    printf '{"config":%s}' "$(cat "$SUBS_JSON")"
                else
                    printf '{"config":{"log_level":"warn","subscriptions":[]}}'
                fi
                ;;

            set_config)
                read -r input
                # Extract the "config" field as raw JSON and write to file
                if echo "$input" | jq -e '.config' > /dev/null 2>&1; then
                    mkdir -p "$(dirname "$SUBS_JSON")"
                    echo "$input" | jq '.config' > "$SUBS_JSON"
                    printf '{"result":"ok"}'
                else
                    printf '{"error":"Invalid config JSON"}'
                fi
                ;;

            run_script)
                if [ ! -f "$SUBS_SCRIPT" ]; then
                    printf '{"error":"Script not found: %s"}' "$SUBS_SCRIPT"
                    exit 0
                fi
                if [ ! -x "$SUBS_SCRIPT" ]; then
                    chmod +x "$SUBS_SCRIPT"
                fi
                # Parse optional params: {"dry_run": bool, "verbose": number}
                read -r input
                dry_run=$(echo "$input" | jq -r '.dry_run // false')
                verbose=$(echo "$input"  | jq -r '.verbose  // 2')

                # Build command + options
                [ "$dry_run" = "true" ] && cmd="dry-run" || cmd="run"
                args="$cmd"
                case "$verbose" in
                    1) args="$args -v"   ;;
                    2) args="$args -vv"  ;;
                    3) args="$args -vvv" ;;
                esac

                # Truncate log so the frontend sees only the current run
                : > "$LOG_FILE"
                # shellcheck disable=SC2086
                sh "$SUBS_SCRIPT" $args > /dev/null 2>&1 &
                echo $! > "$PID_FILE"
                printf '{"result":"started"}'
                ;;

            get_log)
                running=false
                if [ -f "$PID_FILE" ]; then
                    pid=$(cat "$PID_FILE")
                    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        running=true
                    fi
                fi
                if [ -f "$LOG_FILE" ]; then
                    log_json=$(jq -Rs '.' "$LOG_FILE")
                else
                    log_json='""'
                fi
                printf '{"log":%s,"running":%s}' "$log_json" "$running"
                ;;

            test_url)
                read -r input
                url=$(echo "$input" | jq -r '.url // ""')

                case "$url" in
                    http://*|https://*) ;;
                    *) printf '{"error":"Invalid URL"}'; exit 0 ;;
                esac

                # Extract domain (strip protocol, path, query, port)
                domain=$(echo "$url" | sed 's|https\?://||;s|[/?#].*||;s|:.*||')

                # 1. Test request through tun0 — capture HTTP status code
                vpn_http_code=$(curl --interface tun0 -s --max-time 15 \
                    -o /dev/null -w "%{http_code}" "$url" 2>/dev/null)
                vpn_ok=false
                case "$vpn_http_code" in [1-9][0-9][0-9]) vpn_ok=true ;; esac

                # 2. Determine outbound from config.json routing rules
                outbound=""
                config_json="/etc/sing-box/config.json"
                if [ -f "$config_json" ]; then
                    outbound=$(jq -r --arg d "$domain" '
                        [
                          .route.rules[]? |
                          select(.domain_suffix != null) |
                          select(
                            .domain_suffix |
                            map(. as $s | ($d == $s) or ($d | endswith("." + $s))) |
                            any
                          ) |
                          .outbound
                        ][0] // ""
                    ' "$config_json" 2>/dev/null)
                    # Fall back to route.final (default outbound)
                    [ -z "$outbound" ] && \
                        outbound=$(jq -r '.route.final // "direct"' "$config_json" 2>/dev/null)
                fi

                jq -n \
                    --arg  domain    "$domain" \
                    --argjson vpn_ok "$vpn_ok" \
                    --arg  http_code "$vpn_http_code" \
                    --arg  outbound  "$outbound" \
                    '{domain:$domain, vpn_ok:$vpn_ok, http_code:$http_code, outbound:$outbound}'
                ;;

            get_sb_status)
                result=$(curl -s --max-time 5 http://127.0.0.1:9090/proxies 2>/dev/null)
                if [ -f "$TAGS_FILE" ]; then
                    tag_names=$(cat "$TAGS_FILE")
                else
                    tag_names='{}'
                fi
                if echo "$result" | jq -e '.proxies' > /dev/null 2>&1; then
                    echo "$result" | jq --argjson tn "$tag_names" '. + {tag_names: $tn}'
                else
                    printf '{"proxies":{},"tag_names":{}}'
                fi
                ;;

            set_proxy)
                read -r input
                proxy=$(echo "$input" | jq -r '.proxy // ""')
                selected=$(echo "$input" | jq -r '.selected // ""')

                if [ -z "$proxy" ] || [ -z "$selected" ]; then
                    printf '{"error":"Missing proxy or selected"}'
                    exit 0
                fi

                # Tags use only alphanumeric and hyphens — no URL encoding needed
                result=$(curl -s -X PUT \
                    -H "Content-Type: application/json" \
                    -d "{\"name\":\"${selected}\"}" \
                    --max-time 5 \
                    "http://127.0.0.1:9090/proxies/${proxy}" 2>/dev/null)
                # Clash API returns 204 No Content on success
                printf '{"result":"ok"}'
                ;;

            test_delays)
                read -r input
                test_url=$(echo "$input" | jq -r '.url // "https://www.gstatic.com/generate_204"')
                # URL-encode test_url for use as query parameter
                enc_url=$(printf '%s' "$test_url" | sed \
                    -e 's/%/%25/g' -e 's/ /%20/g' -e 's/:/%3A/g' \
                    -e 's|/|%2F|g' -e 's/?/%3F/g' -e 's/&/%26/g' \
                    -e 's/=/%3D/g' -e 's/+/%2B/g' -e 's/#/%23/g')
                tmpd=$(mktemp -d /tmp/horn-vpn-dly-XXXXXX)
                # Run delay tests in parallel
                while IFS= read -r tag; do
                    [ -z "$tag" ] && continue
                    (
                        resp=$(curl -s --max-time 8 \
                            "http://127.0.0.1:9090/proxies/${tag}/delay?url=${enc_url}&timeout=5000" \
                            2>/dev/null)
                        delay=$(echo "$resp" | jq -r '.delay // 0' 2>/dev/null || echo 0)
                        printf '%s\t%s\n' "$tag" "${delay:-0}" > "${tmpd}/${tag}"
                    ) &
                done <<TAGEOF
$(echo "$input" | jq -r '.tags[]? // empty')
TAGEOF
                wait
                # Build JSON result from temp files
                result='{'
                sep=''
                for f in "${tmpd}"/*; do
                    [ -f "$f" ] || continue
                    tag=$(cut -f1 < "$f")
                    delay=$(cut -f2 < "$f")
                    result="${result}${sep}\"${tag}\":${delay:-0}"
                    sep=','
                done
                result="${result}}"
                rm -rf "$tmpd"
                printf '{"delays":%s}' "$result"
                ;;

            get_syslog)
                read -r input
                lines=$(echo "$input" | jq -r '.lines // 200')
                # Validate: must be a positive integer
                case "$lines" in
                    ''|*[!0-9]*) lines=200 ;;
                esac
                syslog=$(logread -e sing-box 2>/dev/null | tail -n "$lines")
                printf '{"log":%s}' "$(printf '%s' "$syslog" | jq -Rs '.')"
                ;;

            get_template)
                if [ -f "$TEMPLATE_FILE" ]; then
                    printf '{"template":%s}' "$(jq -Rs '.' "$TEMPLATE_FILE")"
                else
                    printf '{"error":"Template file not found: %s"}' "$TEMPLATE_FILE"
                fi
                ;;

            set_template)
                read -r input
                tmpl=$(echo "$input" | jq -r '.template // ""')
                if [ -z "$tmpl" ]; then
                    printf '{"error":"Empty template"}'
                    exit 0
                fi
                if echo "$tmpl" | jq -e '.' > /dev/null 2>&1; then
                    printf '%s' "$tmpl" > "$TEMPLATE_FILE"
                    printf '{"result":"ok"}'
                else
                    printf '{"error":"Invalid JSON"}'
                fi
                ;;

            reset_template)
                if [ ! -f "$DEFAULT_TEMPLATE_FILE" ]; then
                    printf '{"error":"Default template not found: %s"}' "$DEFAULT_TEMPLATE_FILE"
                    exit 0
                fi
                cp "$DEFAULT_TEMPLATE_FILE" "$TEMPLATE_FILE"
                printf '{"template":%s}' "$(jq -Rs '.' "$TEMPLATE_FILE")"
                ;;

            get_domains_config)
                if [ -f "$DOMAINS_JSON" ]; then
                    printf '{"config":%s}' "$(cat "$DOMAINS_JSON")"
                else
                    printf '{"config":{"domains_url":"","subnet_urls":[]}}'
                fi
                ;;

            set_domains_config)
                read -r input
                if echo "$input" | jq -e '.config' > /dev/null 2>&1; then
                    mkdir -p "$(dirname "$DOMAINS_JSON")"
                    echo "$input" | jq '.config' > "$DOMAINS_JSON"
                    printf '{"result":"ok"}'
                else
                    printf '{"error":"Invalid config JSON"}'
                fi
                ;;

            get_manual_ips)
                if [ -f "$MANUAL_IPS" ]; then
                    printf '{"ips":%s}' "$(jq -Rs '.' "$MANUAL_IPS")"
                else
                    printf '{"ips":""}'
                fi
                ;;

            set_manual_ips)
                read -r input
                ips=$(echo "$input" | jq -r '.ips // ""')
                mkdir -p "$(dirname "$MANUAL_IPS")"
                printf '%s' "$ips" > "$MANUAL_IPS"
                printf '{"result":"ok"}'
                ;;

            run_getdomains)
                if [ ! -f "$DOMAINS_SCRIPT" ]; then
                    printf '{"error":"Script not found: %s"}' "$DOMAINS_SCRIPT"
                    exit 0
                fi
                if [ ! -x "$DOMAINS_SCRIPT" ]; then
                    chmod +x "$DOMAINS_SCRIPT"
                fi
                read -r input
                verbose=$(echo "$input" | jq -r '.verbose // 2')
                args="run"
                case "$verbose" in
                    1) args="$args -v"   ;;
                    2) args="$args -vv"  ;;
                    3) args="$args -vvv" ;;
                esac
                : > "$DOMAINS_LOG"
                # shellcheck disable=SC2086
                sh "$DOMAINS_SCRIPT" $args > /dev/null 2>&1 &
                echo $! > "$DOMAINS_PID"
                printf '{"result":"started"}'
                ;;

            get_domains_log)
                running=false
                if [ -f "$DOMAINS_PID" ]; then
                    pid=$(cat "$DOMAINS_PID")
                    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        running=true
                    fi
                fi
                if [ -f "$DOMAINS_LOG" ]; then
                    log_json=$(jq -Rs '.' "$DOMAINS_LOG")
                else
                    log_json='""'
                fi
                printf '{"log":%s,"running":%s}' "$log_json" "$running"
                ;;

            get_manual_domains)
                if [ ! -f /etc/config/dhcp ]; then
                    printf '{"domains":[]}'
                    exit 0
                fi
                domains_json=$(awk '
                    /^config ipset/ { is_vpn=0; in_ipset=1; next }
                    /^config /      { is_vpn=0; in_ipset=0; next }
                    in_ipset && /list name/ && /vpn_domains/ { is_vpn=1; next }
                    in_ipset && is_vpn && /list domain / {
                        line=$0
                        sub(/^[[:space:]]*list domain ./, "", line)
                        sub(/.[[:space:]]*$/, "", line)
                        print line
                    }
                ' /etc/config/dhcp | jq -Rs '[split("\n")[] | select(. != "")]')
                printf '{"domains":%s}' "$domains_json"
                ;;

            set_manual_domains)
                read -r input
                if [ ! -f /etc/config/dhcp ]; then
                    printf '{"error":"File not found: /etc/config/dhcp"}'
                    exit 0
                fi

                # Collect old domains (sorted) to detect changes
                old_domains=$(awk '
                    /^config ipset/ { is_vpn=0; in_ipset=1; next }
                    /^config /      { is_vpn=0; in_ipset=0; next }
                    in_ipset && /list name/ && /vpn_domains/ { is_vpn=1; next }
                    in_ipset && is_vpn && /list domain / {
                        line=$0
                        sub(/^[[:space:]]*list domain ./, "", line)
                        sub(/.[[:space:]]*$/, "", line)
                        print line
                    }
                ' /etc/config/dhcp | sort)

                new_domains=$(echo "$input" | jq -r '.domains[]? // empty' | sort)

                # Strip existing vpn_domains ipset blocks
                stripped=$(awk '
                    function flush() { if (!is_vpn && buf != "") printf "%s", buf }
                    /^config ipset/ { flush(); buf=$0"\n"; is_vpn=0; in_ipset=1; next }
                    /^config /      { flush(); buf=$0"\n"; is_vpn=0; in_ipset=0; next }
                    in_ipset && /list name/ && /vpn_domains/ { is_vpn=1; buf=buf$0"\n"; next }
                    { buf=buf$0"\n" }
                    END { flush() }
                ' /etc/config/dhcp)

                # Rewrite the file: stripped content + new domain blocks
                {
                    printf '%s' "$stripped"
                    echo "$input" | jq -r '.domains[]? // empty' | while IFS= read -r domain; do
                        [ -z "$domain" ] && continue
                        printf 'config ipset\n\tlist name '\''vpn_domains'\''\n\tlist domain '\''%s'\''\n\n' "$domain"
                    done
                } > /etc/config/dhcp

                if [ "$new_domains" != "$old_domains" ]; then
                    /etc/init.d/dnsmasq restart > /dev/null 2>&1
                    printf '{"result":"ok","restarted":true}'
                else
                    printf '{"result":"ok","restarted":false}'
                fi
                ;;

            *)
                printf '{"error":"Unknown method"}'
                ;;
        esac
        ;;
esac
