#!/bin/sh
# shellcheck disable=SC3043

CONF_DIR="/etc/horn-vpn-manager"
CONFIG_FILE="${CONF_DIR}/config.json"
CUSTOM_TEMPLATE="${CONF_DIR}/sing-box.template.json"
DEFAULT_TEMPLATE_FILE="/usr/share/horn-vpn-manager/sing-box.template.json"
TAGS_FILE="${CONF_DIR}/subs-tags.json"
LOG_FILE="/tmp/horn-vpn-manager-subscriptions.log"
PID_FILE="/tmp/horn-vpn-manager.pid"
ROUTING_LOG="/tmp/horn-vpn-manager-routing.log"
ROUTING_PID="/tmp/horn-vpn-manager-routing.pid"

UNSYNC_SUBS_FLAG="${CONF_DIR}/.needs-update-subs"
UNSYNC_ROUTING_FLAG="${CONF_DIR}/.needs-update-routing"

MANUAL_IPS_DEFAULT="${CONF_DIR}/lists/manual-ip.lst"

case "$1" in
    list)
        echo '{"get_config":{},"set_config":{"config":"Object"},"set_full_config":{"config":"Object","template_contents":"String"},"run_script":{"dry_run":"Boolean","cached_lists":"Boolean","download_lists":"Boolean"},"get_log":{},"get_syslog":{"lines":"Number"},"test_url":{"url":"String"},"get_sb_status":{},"set_proxy":{"proxy":"String","selected":"String"},"test_delays":{"tags":"Array","url":"String"},"get_template":{},"set_template":{"template":"String"},"reset_template":{},"get_domains_config":{},"set_domains_config":{"config":"Object"},"get_manual_ips":{},"set_manual_ips":{"ips":"String"},"run_routing":{"with_subscriptions":"Boolean"},"get_routing_log":{},"get_manual_domains":{},"set_manual_domains":{"domains":"Array"},"get_sync_status":{}}'
        ;;
    call)
        case "$2" in
            get_config)
                if [ -f "$CONFIG_FILE" ]; then
                    # Return singbox settings and the full subscriptions keyed object
                    result=$(jq '{
                        singbox: (.singbox // {}),
                        fetch: (.fetch // {}),
                        subscriptions: (.subscriptions // {})
                    }' "$CONFIG_FILE" 2>/dev/null)
                    if [ -n "$result" ]; then
                        printf '{"config":%s}' "$result"
                    else
                        printf '{"error":"Failed to parse config.json"}'
                    fi
                else
                    printf '{"config":{"singbox":{"log_level":"warn","test_url":"https://www.gstatic.com/generate_204","template":""},"fetch":{},"subscriptions":{}}}'
                fi
                ;;

            set_config)
                read -r input
                if ! echo "$input" | jq -e '.config' > /dev/null 2>&1; then
                    printf '{"error":"Invalid config JSON"}'
                    exit 0
                fi
                new_config=$(echo "$input" | jq '.config')

                # Validate: subscriptions must be an object, not an array
                sub_type=$(echo "$new_config" | jq -r '(.subscriptions) | type')
                if [ "$sub_type" != "object" ]; then
                    printf '{"error":"subscriptions must be a keyed object, not an array"}'
                    exit 0
                fi

                # Validate: subscriptions must be a non-empty object
                sub_count=$(echo "$new_config" | jq '(.subscriptions // {}) | length')
                if [ "$sub_count" -eq 0 ]; then
                    printf '{"error":"At least one subscription is required"}'
                    exit 0
                fi

                # Validate: exactly one default subscription
                def_count=$(echo "$new_config" | jq '[(.subscriptions // {})[] | select(.default == true)] | length')
                if [ "$def_count" -eq 0 ]; then
                    printf '{"error":"At least one enabled default subscription is required"}'
                    exit 0
                fi
                if [ "$def_count" -gt 1 ]; then
                    printf '{"error":"Only one default subscription is allowed"}'
                    exit 0
                fi

                # Validate: default subscription must not be disabled
                def_disabled=$(echo "$new_config" | jq '[(.subscriptions // {})[] | select(.default == true and .enabled == false)] | length')
                if [ "$def_disabled" -gt 0 ]; then
                    printf '{"error":"Default subscription cannot be disabled"}'
                    exit 0
                fi

                # Validate: all subscriptions must have non-empty string name and url
                invalid_fields=$(echo "$new_config" | jq '[(.subscriptions // {}) | to_entries[] | select((.value.name | type) != "string" or (.value.url | type) != "string" or (.value.name // "") == "" or (.value.url // "") == "")] | length')
                if [ "$invalid_fields" -gt 0 ]; then
                    printf '{"error":"All subscriptions must have a non-empty string name and url"}'
                    exit 0
                fi

                # Merge: preserve existing routing section; replace singbox, fetch (if provided), and subscriptions
                if [ -f "$CONFIG_FILE" ]; then
                    existing=$(cat "$CONFIG_FILE")
                else
                    existing='{"singbox":{},"fetch":{},"routing":{},"subscriptions":{}}'
                fi
                merged=$(jq -n \
                    --argjson ex "$existing" \
                    --argjson inp "$new_config" \
                    '
                    ($inp.singbox // {}) as $isb |
                    ($ex.singbox // {}) as $esb |
                    $ex + {
                        singbox: ($esb + $isb + {template: (if (($isb.template // "") != "") then $isb.template else ($esb.template // "") end)}),
                        fetch: (if ($inp | has("fetch")) then ($inp.fetch // {}) else ($ex.fetch // {}) end),
                        subscriptions: ($inp.subscriptions // {})
                    }')
                if [ -z "$merged" ]; then
                    printf '{"error":"Failed to merge config"}'
                    exit 0
                fi
                mkdir -p "$CONF_DIR"
                printf '%s\n' "$merged" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
                touch "$UNSYNC_SUBS_FLAG"
                printf '{"result":"ok"}'
                ;;

            set_full_config)
                read -r input
                if ! echo "$input" | jq -e '.config' > /dev/null 2>&1; then
                    printf '{"error":"Invalid config JSON"}'
                    exit 0
                fi
                new_config=$(echo "$input" | jq '.config')

                # Validate template contents before any writes
                tmpl_contents=$(echo "$input" | jq -r '.template_contents // ""')
                if [ -n "$tmpl_contents" ]; then
                    if ! echo "$tmpl_contents" | jq -e '.' > /dev/null 2>&1; then
                        printf '{"error":"Invalid template JSON"}'
                        exit 0
                    fi
                fi

                # Validate: subscriptions must be an object, not an array
                sub_type=$(echo "$new_config" | jq -r '(.subscriptions) | type')
                if [ "$sub_type" != "object" ]; then
                    printf '{"error":"subscriptions must be a keyed object, not an array"}'
                    exit 0
                fi

                # Validate: subscriptions must be a non-empty object
                sub_count=$(echo "$new_config" | jq '(.subscriptions // {}) | length')
                if [ "$sub_count" -eq 0 ]; then
                    printf '{"error":"At least one subscription is required"}'
                    exit 0
                fi

                # Validate: exactly one default subscription
                def_count=$(echo "$new_config" | jq '[(.subscriptions // {})[] | select(.default == true)] | length')
                if [ "$def_count" -eq 0 ]; then
                    printf '{"error":"At least one enabled default subscription is required"}'
                    exit 0
                fi
                if [ "$def_count" -gt 1 ]; then
                    printf '{"error":"Only one default subscription is allowed"}'
                    exit 0
                fi

                # Validate: default subscription must not be disabled
                def_disabled=$(echo "$new_config" | jq '[(.subscriptions // {})[] | select(.default == true and .enabled == false)] | length')
                if [ "$def_disabled" -gt 0 ]; then
                    printf '{"error":"Default subscription cannot be disabled"}'
                    exit 0
                fi

                # Validate: all subscriptions must have non-empty string name and url
                invalid_fields=$(echo "$new_config" | jq '[(.subscriptions // {}) | to_entries[] | select((.value.name | type) != "string" or (.value.url | type) != "string" or (.value.name // "") == "" or (.value.url // "") == "")] | length')
                if [ "$invalid_fields" -gt 0 ]; then
                    printf '{"error":"All subscriptions must have a non-empty string name and url"}'
                    exit 0
                fi

                # Validate: include and exclude must be arrays of strings if present
                invalid_filter_type=$(echo "$new_config" | jq '[(.subscriptions // {})[] | select((.include != null and (.include | type) != "array") or (.exclude != null and (.exclude | type) != "array"))] | length')
                if [ "$invalid_filter_type" -gt 0 ]; then
                    printf '{"error":"Include and exclude filters must be arrays"}'
                    exit 0
                fi

                # Validate: include and exclude filter entries must be non-empty strings
                invalid_filter_entries=$(echo "$new_config" | jq '[(.subscriptions // {})[] | ((.include // []) + (.exclude // []))[] | select(type != "string" or . == "")] | length')
                if [ "$invalid_filter_entries" -gt 0 ]; then
                    printf '{"error":"Include and exclude filter entries must be non-empty strings"}'
                    exit 0
                fi

                # All validation passed — apply template path update to config before merge
                if [ -n "$tmpl_contents" ]; then
                    new_config=$(echo "$new_config" | jq --arg p "$CUSTOM_TEMPLATE" '.singbox.template = $p')
                fi

                # Build merged config
                if [ -f "$CONFIG_FILE" ]; then
                    existing=$(cat "$CONFIG_FILE")
                else
                    existing='{"singbox":{},"fetch":{},"routing":{},"subscriptions":{}}'
                fi
                merged=$(jq -n \
                    --argjson ex "$existing" \
                    --argjson inp "$new_config" \
                    '
                    ($inp.singbox // {}) as $isb |
                    ($ex.singbox // {}) as $esb |
                    {
                        singbox: ($esb + $isb + {template: ($isb.template // "")}),
                        fetch: (if ($inp | has("fetch")) then ($inp.fetch // {}) else ($ex.fetch // {}) end),
                        routing: (if ($inp | has("routing")) then ($inp.routing // {}) else ($ex.routing // {}) end),
                        subscriptions: ($inp.subscriptions // {})
                    }')
                if [ -z "$merged" ]; then
                    printf '{"error":"Failed to merge config"}'
                    exit 0
                fi

                # Write template first (only after all validation passed)
                mkdir -p "$CONF_DIR"
                if [ -n "$tmpl_contents" ]; then
                    if ! { printf '%s' "$tmpl_contents" > "${CUSTOM_TEMPLATE}.tmp" && mv "${CUSTOM_TEMPLATE}.tmp" "$CUSTOM_TEMPLATE"; }; then
                        printf '{"error":"Failed to write template file"}'
                        exit 0
                    fi
                fi
                if ! { printf '%s\n' "$merged" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"; }; then
                    printf '{"error":"Failed to write config file"}'
                    exit 0
                fi
                touch "$UNSYNC_SUBS_FLAG"
                touch "$UNSYNC_ROUTING_FLAG"
                printf '{"result":"ok"}'
                ;;

            run_script)
                # Reject if a previous run is still active
                if [ -f "$PID_FILE" ]; then
                    pid=$(cat "$PID_FILE")
                    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        printf '{"error":"already running"}'
                        exit 0
                    fi
                fi

                # Parse optional params
                read -r input
                dry_run=$(echo "$input" | jq -r '.dry_run // false')
                cached_lists=$(echo "$input" | jq -r '.cached_lists // false')
                download_lists=$(echo "$input" | jq -r '.download_lists // false')

                # Build subcommand
                [ "$dry_run" = "true" ] && subcmd="dry-run" || subcmd="run"
                args="subscriptions $subcmd"
                [ "$cached_lists" = "true" ]   && args="$args --cached-lists"
                [ "$download_lists" = "true" ]  && args="$args --download-lists"

                # Truncate log so the frontend sees only the current run
                : > "$LOG_FILE"
                # shellcheck disable=SC2086
                if [ "$dry_run" = "true" ]; then
                    (vpn-manager $args >> "$LOG_FILE" 2>&1) &
                else
                    (vpn-manager $args >> "$LOG_FILE" 2>&1; [ $? -eq 0 ] && rm -f "$UNSYNC_SUBS_FLAG") &
                fi
                echo $! > "$PID_FILE"
                printf '{"result":"started"}'
                ;;

            get_log)
                running=false
                if [ -f "$PID_FILE" ]; then
                    pid=$(cat "$PID_FILE")
                    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        running=true
                    fi
                fi
                if [ -f "$LOG_FILE" ]; then
                    log_json=$(jq -Rs '.' "$LOG_FILE")
                else
                    log_json='""'
                fi
                printf '{"log":%s,"running":%s}' "$log_json" "$running"
                ;;

            run_routing)
                # Reject if a previous routing run is still active
                if [ -f "$ROUTING_PID" ]; then
                    pid=$(cat "$ROUTING_PID")
                    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        printf '{"error":"already running"}'
                        exit 0
                    fi
                fi

                read -r input
                with_subs=$(echo "$input" | jq -r '.with_subscriptions // false')

                args="routing run"
                [ "$with_subs" = "true" ] && args="$args --with-subscriptions"

                : > "$ROUTING_LOG"
                # shellcheck disable=SC2086
                (vpn-manager $args >> "$ROUTING_LOG" 2>&1; [ $? -eq 0 ] && rm -f "$UNSYNC_ROUTING_FLAG") &
                echo $! > "$ROUTING_PID"
                printf '{"result":"started"}'
                ;;

            get_routing_log)
                running=false
                if [ -f "$ROUTING_PID" ]; then
                    pid=$(cat "$ROUTING_PID")
                    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        running=true
                    fi
                fi
                if [ -f "$ROUTING_LOG" ]; then
                    log_json=$(jq -Rs '.' "$ROUTING_LOG")
                else
                    log_json='""'
                fi
                printf '{"log":%s,"running":%s}' "$log_json" "$running"
                ;;

            test_url)
                read -r input
                url=$(echo "$input" | jq -r '.url // ""')

                case "$url" in
                    http://*|https://*) ;;
                    *) printf '{"error":"Invalid URL"}'; exit 0 ;;
                esac

                # Extract domain (strip protocol, path, query, port)
                domain=$(echo "$url" | sed 's|https\?://||;s|[/?#].*||;s|:.*||')

                # 1. Test request through tun0 — capture HTTP status code
                vpn_http_code=$(curl --interface tun0 -s --max-time 15 \
                    -o /dev/null -w "%{http_code}" "$url" 2>/dev/null)
                vpn_ok=false
                case "$vpn_http_code" in [1-9][0-9][0-9]) vpn_ok=true ;; esac

                # 2. Determine outbound from sing-box config routing rules
                outbound=""
                sb_config="/etc/sing-box/config.json"
                if [ -f "$sb_config" ]; then
                    outbound=$(jq -r --arg d "$domain" '
                        [
                          .route.rules[]? |
                          select(.domain_suffix != null) |
                          select(
                            .domain_suffix |
                            map(. as $s | ($d == $s) or ($d | endswith("." + $s))) |
                            any
                          ) |
                          .outbound
                        ][0] // ""
                    ' "$sb_config" 2>/dev/null)
                    [ -z "$outbound" ] && \
                        outbound=$(jq -r '.route.final // "direct"' "$sb_config" 2>/dev/null)
                fi

                jq -n \
                    --arg  domain    "$domain" \
                    --argjson vpn_ok "$vpn_ok" \
                    --arg  http_code "$vpn_http_code" \
                    --arg  outbound  "$outbound" \
                    '{domain:$domain, vpn_ok:$vpn_ok, http_code:$http_code, outbound:$outbound}'
                ;;

            get_sb_status)
                result=$(curl -s --max-time 5 http://127.0.0.1:9090/proxies 2>/dev/null)
                if [ -f "$TAGS_FILE" ]; then
                    tag_names=$(cat "$TAGS_FILE")
                else
                    tag_names='{}'
                fi
                if echo "$result" | jq -e '.proxies' > /dev/null 2>&1; then
                    echo "$result" | jq --argjson tn "$tag_names" '. + {tag_names: $tn}'
                else
                    printf '{"proxies":{},"tag_names":{}}'
                fi
                ;;

            set_proxy)
                read -r input
                proxy=$(echo "$input" | jq -r '.proxy // ""')
                selected=$(echo "$input" | jq -r '.selected // ""')

                if [ -z "$proxy" ] || [ -z "$selected" ]; then
                    printf '{"error":"Missing proxy or selected"}'
                    exit 0
                fi

                # Validate: tags use only alphanumeric, hyphens, underscores, and dots
                case "$proxy" in
                    *[!A-Za-z0-9._-]*) printf '{"error":"Invalid proxy name"}'; exit 0 ;;
                esac
                case "$selected" in
                    *[!A-Za-z0-9._-]*) printf '{"error":"Invalid selected name"}'; exit 0 ;;
                esac

                body=$(jq -n --arg name "$selected" '{"name":$name}')
                curl -s -X PUT \
                    -H "Content-Type: application/json" \
                    -d "$body" \
                    --max-time 5 \
                    "http://127.0.0.1:9090/proxies/${proxy}" > /dev/null 2>/dev/null
                printf '{"result":"ok"}'
                ;;

            test_delays)
                read -r input
                test_url=$(echo "$input" | jq -r '.url // "https://www.gstatic.com/generate_204"')
                case "$test_url" in
                    http://*|https://*) ;;
                    *) printf '{"error":"Invalid URL"}'; exit 0 ;;
                esac
                # URL-encode test_url for use as query parameter
                enc_url=$(printf '%s' "$test_url" | sed \
                    -e 's/%/%25/g' -e 's/ /%20/g' -e 's/:/%3A/g' \
                    -e 's|/|%2F|g' -e 's/?/%3F/g' -e 's/&/%26/g' \
                    -e 's/=/%3D/g' -e 's/+/%2B/g' -e 's/#/%23/g')
                tmpd=$(mktemp -d /tmp/horn-vpn-dly-XXXXXX)
                # Run delay tests in parallel
                while IFS= read -r tag; do
                    [ -z "$tag" ] && continue
                    # Validate: tags use only alphanumeric, hyphens, underscores, and dots
                    case "$tag" in
                        *[!A-Za-z0-9._-]*) continue ;;
                    esac
                    (
                        resp=$(curl -s --max-time 8 \
                            "http://127.0.0.1:9090/proxies/${tag}/delay?url=${enc_url}&timeout=5000" \
                            2>/dev/null)
                        delay=$(echo "$resp" | jq -r '.delay // 0' 2>/dev/null || echo 0)
                        printf '%s\t%s\n' "$tag" "${delay:-0}" > "${tmpd}/${tag}"
                    ) &
                done <<TAGEOF
$(echo "$input" | jq -r '.tags[]? // empty')
TAGEOF
                wait
                # Build JSON result from temp files using jq for safe encoding
                delays_json=$(
                    for f in "${tmpd}"/*; do
                        [ -f "$f" ] || continue
                        tag=$(cut -f1 < "$f")
                        delay=$(cut -f2 < "$f")
                        printf '%s\t%s\n' "$tag" "${delay:-0}"
                    done | jq -Rn '[inputs | split("\t")] | map({(.[0]): (.[1] | tonumber)}) | add // {}'
                )
                rm -rf "$tmpd"
                printf '{"delays":%s}' "$delays_json"
                ;;

            get_syslog)
                read -r input
                lines=$(echo "$input" | jq -r '.lines // 200')
                # Validate: must be a positive integer
                case "$lines" in
                    ''|*[!0-9]*) lines=200 ;;
                esac
                syslog=$(logread -e sing-box 2>/dev/null | tail -n "$lines")
                printf '{"log":%s}' "$(printf '%s' "$syslog" | jq -Rs '.')"
                ;;

            get_template)
                # Determine template path: custom path from config, then default on-device file
                tmpl_path=""
                if [ -f "$CONFIG_FILE" ]; then
                    tmpl_path=$(jq -r '.singbox.template // ""' "$CONFIG_FILE" 2>/dev/null)
                fi
                # Fall back to default on-device template
                [ -z "$tmpl_path" ] && tmpl_path="$DEFAULT_TEMPLATE_FILE"

                if [ -f "$tmpl_path" ]; then
                    printf '{"template":%s}' "$(jq -Rs '.' "$tmpl_path")"
                else
                    printf '{"error":"Template file not found: %s"}' "$tmpl_path"
                fi
                ;;

            set_template)
                read -r input
                tmpl=$(echo "$input" | jq -r '.template // ""')
                if [ -z "$tmpl" ]; then
                    printf '{"error":"Empty template"}'
                    exit 0
                fi
                if ! echo "$tmpl" | jq -e '.' > /dev/null 2>&1; then
                    printf '{"error":"Invalid JSON"}'
                    exit 0
                fi
                mkdir -p "$CONF_DIR"
                printf '%s' "$tmpl" > "${CUSTOM_TEMPLATE}.tmp" && mv "${CUSTOM_TEMPLATE}.tmp" "$CUSTOM_TEMPLATE"
                # Update config.json → singbox.template to point to custom template
                if [ -f "$CONFIG_FILE" ]; then
                    existing_cfg=$(cat "$CONFIG_FILE")
                else
                    existing_cfg='{"singbox":{},"fetch":{},"routing":{},"subscriptions":{}}'
                fi
                updated=$(printf '%s' "$existing_cfg" | jq --arg p "$CUSTOM_TEMPLATE" '.singbox.template = $p')
                printf '%s\n' "$updated" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
                touch "$UNSYNC_SUBS_FLAG"
                printf '{"result":"ok"}'
                ;;

            reset_template)
                # Remove custom template file and clear config.json → singbox.template field
                rm -f "$CUSTOM_TEMPLATE"
                if [ -f "$CONFIG_FILE" ]; then
                    updated=$(jq '.singbox.template = ""' "$CONFIG_FILE")
                    if [ -z "$updated" ]; then
                        printf '{"error":"Failed to update config"}'
                        exit 0
                    fi
                    printf '%s\n' "$updated" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
                fi
                touch "$UNSYNC_SUBS_FLAG"
                # Return the default template content for display
                if [ -f "$DEFAULT_TEMPLATE_FILE" ]; then
                    printf '{"template":%s}' "$(jq -Rs '.' "$DEFAULT_TEMPLATE_FILE")"
                else
                    printf '{"result":"ok"}'
                fi
                ;;

            get_domains_config)
                if [ -f "$CONFIG_FILE" ]; then
                    routing=$(jq '.routing // {}' "$CONFIG_FILE" 2>/dev/null)
                    printf '{"config":%s}' "$routing"
                else
                    printf '{"config":{}}'
                fi
                ;;

            set_domains_config)
                read -r input
                if ! echo "$input" | jq -e '.config' > /dev/null 2>&1; then
                    printf '{"error":"Invalid config JSON"}'
                    exit 0
                fi
                new_routing=$(echo "$input" | jq '.config')
                # Merge into existing config, replacing only the routing section
                if [ -f "$CONFIG_FILE" ]; then
                    existing=$(cat "$CONFIG_FILE")
                else
                    existing='{"singbox":{},"fetch":{},"routing":{},"subscriptions":{}}'
                fi
                merged=$(jq -n \
                    --argjson ex "$existing" \
                    --argjson r "$new_routing" \
                    '$ex + {routing: (($ex.routing // {}) + $r + {subnets: (($ex.routing.subnets // {}) + ($r.subnets // {}))})}' \
                )
                mkdir -p "$CONF_DIR"
                printf '%s\n' "$merged" > "${CONFIG_FILE}.tmp" && mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"
                touch "$UNSYNC_ROUTING_FLAG"
                printf '{"result":"ok"}'
                ;;

            get_manual_ips)
                manual_file="$MANUAL_IPS_DEFAULT"
                if [ -f "$CONFIG_FILE" ]; then
                    cf=$(jq -r '.routing.subnets.manual_file // ""' "$CONFIG_FILE" 2>/dev/null)
                    case "$cf" in
                        /etc/horn-vpn-manager/*)
                            case "$cf" in
                                *../*|*/..*) ;;
                                *) manual_file="$cf" ;;
                            esac
                            ;;
                    esac
                fi
                if [ -f "$manual_file" ]; then
                    printf '{"ips":%s}' "$(jq -Rs '.' "$manual_file")"
                else
                    printf '{"ips":""}'
                fi
                ;;

            set_manual_ips)
                read -r input
                ips=$(echo "$input" | jq -r '.ips // ""')
                manual_file="$MANUAL_IPS_DEFAULT"
                if [ -f "$CONFIG_FILE" ]; then
                    cf=$(jq -r '.routing.subnets.manual_file // ""' "$CONFIG_FILE" 2>/dev/null)
                    case "$cf" in
                        /etc/horn-vpn-manager/*)
                            case "$cf" in
                                *../*|*/..*) ;;
                                *) manual_file="$cf" ;;
                            esac
                            ;;
                    esac
                fi
                mkdir -p "$(dirname "$manual_file")"
                printf '%s' "$ips" > "${manual_file}.tmp" && mv "${manual_file}.tmp" "$manual_file"
                printf '{"result":"ok"}'
                ;;

            get_manual_domains)
                if [ ! -f /etc/config/dhcp ]; then
                    printf '{"domains":[]}'
                    exit 0
                fi
                domains_json=$(awk '
                    /^config ipset/ { is_vpn=0; in_ipset=1; next }
                    /^config /      { is_vpn=0; in_ipset=0; next }
                    in_ipset && /list name/ && /vpn_domains/ { is_vpn=1; next }
                    in_ipset && is_vpn && /list domain / {
                        line=$0
                        sub(/^[[:space:]]*list domain ./, "", line)
                        sub(/.[[:space:]]*$/, "", line)
                        print line
                    }
                ' /etc/config/dhcp | jq -Rs '[split("\n")[] | select(. != "")]')
                printf '{"domains":%s}' "$domains_json"
                ;;

            set_manual_domains)
                read -r input
                if [ ! -f /etc/config/dhcp ]; then
                    printf '{"error":"File not found: /etc/config/dhcp"}'
                    exit 0
                fi

                # Collect old domains (sorted) to detect changes
                old_domains=$(awk '
                    /^config ipset/ { is_vpn=0; in_ipset=1; next }
                    /^config /      { is_vpn=0; in_ipset=0; next }
                    in_ipset && /list name/ && /vpn_domains/ { is_vpn=1; next }
                    in_ipset && is_vpn && /list domain / {
                        line=$0
                        sub(/^[[:space:]]*list domain ./, "", line)
                        sub(/.[[:space:]]*$/, "", line)
                        print line
                    }
                ' /etc/config/dhcp | sort)

                new_domains=$(echo "$input" | jq -r '.domains[]? // empty' | sort)

                # Strip existing vpn_domains ipset blocks
                stripped=$(awk '
                    function flush() { if (!is_vpn && buf != "") printf "%s", buf }
                    /^config ipset/ { flush(); buf=$0"\n"; is_vpn=0; in_ipset=1; next }
                    /^config /      { flush(); buf=$0"\n"; is_vpn=0; in_ipset=0; next }
                    in_ipset && /list name/ && /vpn_domains/ { is_vpn=1; buf=buf$0"\n"; next }
                    { buf=buf$0"\n" }
                    END { flush() }
                ' /etc/config/dhcp)

                # Rewrite the file: stripped content + new domain blocks
                {
                    printf '%s\n' "$stripped"
                    echo "$input" | jq -r '.domains[]? // empty' | while IFS= read -r domain; do
                        [ -z "$domain" ] && continue
                        # Validate: domains contain only safe characters (alphanumeric, hyphens, dots)
                        case "$domain" in
                            *[!A-Za-z0-9.-]*) continue ;;
                        esac
                        printf 'config ipset\n\tlist name '\''vpn_domains'\''\n\tlist domain '\''%s'\''\n\n' "$domain"
                    done
                } > /etc/config/dhcp.tmp && mv /etc/config/dhcp.tmp /etc/config/dhcp

                if [ "$new_domains" != "$old_domains" ]; then
                    /etc/init.d/dnsmasq restart > /dev/null 2>&1
                    printf '{"result":"ok","restarted":true}'
                else
                    printf '{"result":"ok","restarted":false}'
                fi
                ;;

            get_sync_status)
                subs_pending=false
                routing_pending=false
                [ -f "$UNSYNC_SUBS_FLAG" ] && subs_pending=true
                [ -f "$UNSYNC_ROUTING_FLAG" ] && routing_pending=true
                if [ "$subs_pending" = "true" ] || [ "$routing_pending" = "true" ]; then
                    printf '{"synced":false,"subs_pending":%s,"routing_pending":%s}' "$subs_pending" "$routing_pending"
                else
                    printf '{"synced":true,"subs_pending":false,"routing_pending":false}'
                fi
                ;;

            *)
                printf '{"error":"Unknown method"}'
                ;;
        esac
        ;;
esac
