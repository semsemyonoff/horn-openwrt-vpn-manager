#!/bin/sh

SUBS_JSON="/etc/sing-box/subs.json"
SUBS_SCRIPT="/etc/sing-box/subs.sh"
LOG_FILE="/tmp/sing-box-sub.log"
PID_FILE="/tmp/vpnsub.pid"

case "$1" in
    list)
        echo '{"get_config":{},"set_config":{"config":"String"},"run_script":{"dry_run":"Boolean","verbose":"Number"},"get_log":{},"get_syslog":{"lines":"Number"},"test_url":{"url":"String"},"get_sb_status":{}}'
        ;;
    call)
        case "$2" in
            get_config)
                if [ -f "$SUBS_JSON" ]; then
                    printf '{"config":%s}' "$(cat "$SUBS_JSON")"
                else
                    printf '{"config":{"log_level":"warn","subscriptions":[]}}'
                fi
                ;;

            set_config)
                read -r input
                # Extract the "config" field as raw JSON and write to file
                if echo "$input" | jq -e '.config' > /dev/null 2>&1; then
                    echo "$input" | jq '.config' > "$SUBS_JSON"
                    printf '{"result":"ok"}'
                else
                    printf '{"error":"Invalid config JSON"}'
                fi
                ;;

            run_script)
                if [ ! -f "$SUBS_SCRIPT" ]; then
                    printf '{"error":"Script not found: %s"}' "$SUBS_SCRIPT"
                    exit 0
                fi
                if [ ! -x "$SUBS_SCRIPT" ]; then
                    chmod +x "$SUBS_SCRIPT"
                fi
                # Parse optional params: {"dry_run": bool, "verbose": number}
                read -r input
                dry_run=$(echo "$input" | jq -r '.dry_run // false')
                verbose=$(echo "$input"  | jq -r '.verbose  // 2')

                # Build argument list (default: -vv)
                args=""
                [ "$dry_run" = "true" ] && args="$args --dry-run"
                case "$verbose" in
                    1) args="$args -v"   ;;
                    2) args="$args -vv"  ;;
                    3) args="$args -vvv" ;;
                esac

                # Truncate log so the frontend sees only the current run
                > "$LOG_FILE"
                # shellcheck disable=SC2086
                sh "$SUBS_SCRIPT" $args > /dev/null 2>&1 &
                echo $! > "$PID_FILE"
                printf '{"result":"started"}'
                ;;

            get_log)
                running=false
                if [ -f "$PID_FILE" ]; then
                    pid=$(cat "$PID_FILE")
                    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                        running=true
                    fi
                fi
                if [ -f "$LOG_FILE" ]; then
                    log_json=$(jq -Rs '.' "$LOG_FILE")
                else
                    log_json='""'
                fi
                printf '{"log":%s,"running":%s}' "$log_json" "$running"
                ;;

            test_url)
                read -r input
                url=$(echo "$input" | jq -r '.url // ""')

                case "$url" in
                    http://*|https://*) ;;
                    *) printf '{"error":"Invalid URL"}'; exit 0 ;;
                esac

                # Extract domain (strip protocol, path, query, port)
                domain=$(echo "$url" | sed 's|https\?://||;s|[/?#].*||;s|:.*||')

                # 1. Test request through tun0 — capture HTTP status code
                vpn_http_code=$(curl --interface tun0 -s --max-time 15 \
                    -o /dev/null -w "%{http_code}" "$url" 2>/dev/null)
                vpn_ok=false
                case "$vpn_http_code" in [1-9][0-9][0-9]) vpn_ok=true ;; esac

                # 2. Determine outbound from config.json routing rules
                outbound=""
                config_json="/etc/sing-box/config.json"
                if [ -f "$config_json" ]; then
                    outbound=$(jq -r --arg d "$domain" '
                        [
                          .route.rules[]? |
                          select(.domain_suffix != null) |
                          select(
                            .domain_suffix |
                            map(. as $s | ($d == $s) or ($d | endswith("." + $s))) |
                            any
                          ) |
                          .outbound
                        ][0] // ""
                    ' "$config_json" 2>/dev/null)
                    # Fall back to route.final (default outbound)
                    [ -z "$outbound" ] && \
                        outbound=$(jq -r '.route.final // "direct"' "$config_json" 2>/dev/null)
                fi

                jq -n \
                    --arg  domain    "$domain" \
                    --argjson vpn_ok "$vpn_ok" \
                    --arg  http_code "$vpn_http_code" \
                    --arg  outbound  "$outbound" \
                    '{domain:$domain, vpn_ok:$vpn_ok, http_code:$http_code, outbound:$outbound}'
                ;;

            get_sb_status)
                tags_file="/etc/sing-box/subs-tags.json"
                result=$(curl -s --max-time 5 http://127.0.0.1:9090/proxies 2>/dev/null)
                if [ -f "$tags_file" ]; then
                    tag_names=$(cat "$tags_file")
                else
                    tag_names='{}'
                fi
                if echo "$result" | jq -e '.proxies' > /dev/null 2>&1; then
                    echo "$result" | jq --argjson tn "$tag_names" '. + {tag_names: $tn}'
                else
                    printf '{"proxies":{},"tag_names":{}}'
                fi
                ;;

            get_syslog)
                read -r input
                lines=$(echo "$input" | jq -r '.lines // 200')
                # Validate: must be a positive integer
                case "$lines" in
                    ''|*[!0-9]*) lines=200 ;;
                esac
                syslog=$(logread -e sing-box 2>/dev/null | tail -n "$lines")
                printf '{"log":%s}' "$(printf '%s' "$syslog" | jq -Rs '.')"
                ;;

            *)
                printf '{"error":"Unknown method"}'
                ;;
        esac
        ;;
esac
